@app.route("/terima/<id>")
def terima(id):

    for b in booking:

        if b["id"]==id:

            b["status"]="DITERIMA"

    return redirect("/")

@app.route("/tolak/<id>")
def tolak(id):

    for b in booking:

        if b["id"]==id:

            b["status"]="DITOLAK"

    return redirect("/")

