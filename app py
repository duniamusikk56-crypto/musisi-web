<h3>Chat</h3>

<form method="post" action="/chat/{login}/{nama}">
<input name="pesan">
<button>Kirim</button>
</form>

<hr>
"""

            page+="<h3>Riwayat Booking</h3>"

            for b in booking:

                if b["tujuan"]==nama:

                    page+=f"""

Pemesan : {b['pemesan']}<br>
Tanggal : {b['tanggal']}<br>
Lokasi : {b['lokasi']}<br>
Metode : {b['metode']}<br>
Status : {b['status']}<br>

"""

                    if b["status"]=="MENUNGGU":

                        page+=f"""
<a href="/terima/{b['id']}">TERIMA</a>
<a href="/tolak/{b['id']}">TOLAK</a>
"""

                    page+="<hr>"

            page+="<h3>Chat Masuk</h3>"

            for c in chat:

                if c["tujuan"]==nama:

                    page+=c["pengirim"]+" : "+c["pesan"]+"<br>"

            page+="<hr><h3>Rating</h3>"

            total=0
            jml=0

            for r in rating:

                if r["nama"]==nama:

                    total+=int(r["nilai"])
                    jml+=1

            if jml>0:

                page+="Rating : "+str(round(total/jml,1))

            return page

    return "User tidak ditemukan"

@app.route("/chat/<login>/<nama>",methods=["POST"])
def chat_kirim(login,nama):

    chat.append({
        "pengirim":login,
        "tujuan":nama,
        "pesan":request.form["pesan"]
    })

    return redirect("/profil/"+login+"/"+nama)

@app.route("/booking/<login>/<nama>",methods=["POST"])
def booking_job(login,nama):

    tanggal=request.form["tanggal"]

    for b in booking:

        if b["tujuan"]==nama and b["tanggal"]==tanggal:

            return "Tanggal sudah dibooking"

    data={
        "id":str(uuid.uuid4()),
        "pemesan":login,
        "tujuan":nama,
        "tanggal":tanggal,
        "lokasi":request.form["lokasi"],
        "ket":request.form["ket"],
        "metode":request.form["metode"],
        "status":"MENUNGGU"
    }

    booking.append(data)

    if request.form["metode"]=="DP":

        return redirect("/pembayaran/"+login)

    return redirect("/dashboard/"+login)

